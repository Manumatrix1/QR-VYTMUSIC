rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Organizador certamen: acceso sin login (uso interno) ──
    match /organizador_estado/{docId} {
      allow read, write: if true;
    }
    match /organizador_guardados/{docId} {
      allow read, write: if true;
    }

    // ── Usuarios autenticados (admins) tienen acceso total ──
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // ── Configuración del sitio: admins escriben, público solo lee ──
    match /config_sitio/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Eventos: lectura pública (para cargar configuración de precio/fecha en preventa) ──
    match /events/{eventId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // ── Votos de jurados: escritura permitida con auth (incluyendo anónima) ──
    match /events/{eventId}/jury_evaluations/{docId} {
      allow read: if true;
      allow write: if request.auth != null; // signInAnonymously satisface esta condición
    }

    // ── Artistas de eventos: el organizador puede reasignarlos sin login ──
    match /events/{eventId}/artists/{docId} {
      allow read, write: if true;
    }

    // ── Subcolecciones de eventos: tickets públicos (para ver_entradas.html) ──
    match /events/{eventId}/{sub}/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Grupos de eventos: lectura pública (para centro de reportes y diagnóstico) ──
    match /event_groups/{groupId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Colección pública: audiciones desde la landing page ──
    match /audiciones/{docId} {
      // Crear desde el formulario público
      allow create: if request.resource.data.keys().hasAll(['nombre','telefono'])
                    && request.resource.data.nombre is string
                    && request.resource.data.nombre.size() >= 3
                    && request.resource.data.nombre.size() <= 80
                    && request.resource.data.telefono is string
                    && request.resource.data.telefono.size() >= 7;
      // Leer desde pago_inscripcion.html (sin login)
      allow read: if true;
      // Actualizar solo los campos de pago (comprobante) desde pago_inscripcion.html
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['estadoPago','comprobante_url','comprobante_fecha']);
    }

    // ── Captura de leads de email desde la landing ──
    match /leads_email/{docId} {
      allow create: if request.resource.data.keys().hasAll(['email','fuente','fecha'])
                    && request.resource.data.email is string
                    && request.resource.data.email.size() >= 5
                    && request.resource.data.email.size() <= 120;
      allow read, update, delete: if request.auth != null;
    }

    // ── Preventa de entradas: artistas sin login pueden crear y actualizar su orden ──
    // Colecciones dinámicas ticket_orders_{eventId}
    match /{colId}/{docId} {
      allow create, update, read: if colId.matches('ticket_orders_.*');
    }

    // ── Pistas de audio: artistas sin login pueden subir, actualizar y eliminar su pista ──
    // Colecciones dinámicas pistas_{eventId}
    match /{colId}/{docId} {
      allow create, update, read, delete: if colId.matches('pistas_.*');
    }

    // ── Artistas (colecciones raíz legacy): portal_pistas y subida_pistas las leen sin auth ──
    match /{colId}/{docId} {
      allow read: if colId.matches('artistas_.*');
    }

    // ── Eventos (colección legacy "eventos" ≠ "events"): lectura pública ──
    match /eventos/{docId} {
      allow read: if true;
    }

    // ── Jurados: lectura pública para selector de login en votacion_jurados_FINAL.html ──
    match /jury_users/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── jury_evaluations global: reportes leen, crear con código válido ──
    match /jury_evaluations/{docId} {
      allow read: if true;
      allow create: if request.resource.data.juryCode != null 
                    && request.resource.data.juryCode is string
                    && request.resource.data.juryCode.size() >= 4;
      allow update: if request.auth != null;
    }

    // ── jury_votes global: crear con código válido, solo admin modifica ──
    match /jury_votes/{docId} {
      allow read: if true;
      allow create: if request.resource.data.juryCode != null;
      allow update: if request.auth != null;
    }

    // ── access_log: escáner QR registra accesos sin auth ──
    match /access_log/{docId} {
      allow create: if true;
      allow read: if request.auth != null;
    }

    // ── admin_notifications: solo el backend escribe, el front solo marca como leída ──
    match /admin_notifications/{docId} {
      allow read: if request.auth != null;
      allow create: if false; // solo Firebase Admin SDK (Cloud Functions) puede crear
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'readAt']);
    }

    // ── Votaciones de jurados: colecciones dinámicas jurados_{eventId} - SOLO LECTURA ──
    match /{colId}/{docId} {
      allow read: if colId.matches('jurados_.*');
      allow write: if request.auth != null;
    }

    // ── Votaciones colecciones dinámicas votaciones_jurados_{eventId} - VALIDAR ESTRUCTURA ──
    match /{colId}/{docId} {
      allow read: if colId.matches('votaciones_jurados_.*');
      allow create: if colId.matches('votaciones_jurados_.*')
                    && request.resource.data.juryCode != null;
      // Jurados pueden actualizar su voto con código válido (no requiere auth admin)
      allow update: if request.auth != null
                    || (colId.matches('votaciones_jurados_.*')
                        && request.resource.data.juryCode != null);
    }

    // ── Subcolecciones de eventos que necesitan write controlado ──

    // Votación de jurados: evaluaciones con validación de esquema completa
    match /events/{eventId}/jury_evaluations/{docId} {
      allow read: if true;
      allow create: if request.resource.data.juryCode is string
                    && request.resource.data.juryCode.size() >= 4
                    && request.resource.data.artistId is string
                    && request.resource.data.artistId.size() > 0;
      // Jurados pueden actualizar su propia evaluación (código válido como alternativa a auth)
      allow update: if request.auth != null
                    || (request.resource.data.juryCode is string
                        && request.resource.data.juryCode.size() >= 4);
    }

    match /events/{eventId}/jury_votes/{docId} {
      allow read: if true;
      allow create: if request.resource.data.juryCode is string
                    && request.resource.data.juryCode.size() >= 4
                    && request.resource.data.artistId is string;
      // Jurados pueden actualizar su voto (código válido como alternativa a auth)
      allow update: if request.auth != null
                    || (request.resource.data.juryCode is string
                        && request.resource.data.juryCode.size() >= 4);
    }

    // Tickets: solo marcar como usados si NO estaba usado ya (prevenir re-escaneo)
    match /events/{eventId}/tickets/{docId} {
      allow read: if true;
      allow update: if
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['used', 'usedAt', 'scannedBy', 'scannedDevice', 'accessTime'])
        && resource.data.used == false
        && request.resource.data.used == true;
    }

    // Artistas: admin puede todo; público solo puede incrementar contadores numéricos
    match /events/{eventId}/artists/{docId} {
      allow read: if true;
      allow update: if request.auth != null
        ||
        // Solo campos de contadores y solo números (nunca strings)
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'totalScore', 'totalSingingScore', 'totalTransmissionScore',
          'totalAttitudeScore', 'totalOriginalityScore', 'totalCostumeScore',
          'totalStagingScore', 'totalRatingsCount'
        ])
        && request.resource.data.totalRatingsCount is number
        && request.resource.data.totalScore is number);
    }

    // Live feedback: abierto (no contiene datos sensibles)
    match /events/{eventId}/live_feedback/{docId} {
      allow read, write: if true;
    }

    // Documento padre ticket_votes: creación pública (voting_page lo necesita)
    match /events/{eventId}/ticket_votes/{ticketId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAny(['ticketId','createdAt','eventId']);
      allow update: if request.auth != null;
    }

    // Voto individual: validación completa de esquema — protege los sorteos de datos corruptos
    match /events/{eventId}/ticket_votes/{ticketId}/votes/{voteId} {
      allow read: if true;
      // Público puede votar y actualizar su voto (re-votación) con datos válidos
      allow create, update: if
        // Campos obligatorios: nombre del votante y artista destino
        request.resource.data.ticketName is string
        && request.resource.data.ticketName.size() >= 1
        && request.resource.data.artistId is string
        && request.resource.data.artistId.size() > 0
        // Todos los puntajes deben ser números en rango 0-5
        && request.resource.data.singingScore is number
        && request.resource.data.singingScore >= 0
        && request.resource.data.singingScore <= 5
        && request.resource.data.transmissionScore is number
        && request.resource.data.transmissionScore >= 0
        && request.resource.data.transmissionScore <= 5
        && request.resource.data.attitudeScore is number
        && request.resource.data.attitudeScore >= 0
        && request.resource.data.attitudeScore <= 5;
    }

    // Sorteos: sistema de premios guarda resultados (sin auth para que funcione en evento en vivo)
    match /sorteos/{docId} {
      allow create: if request.resource.data.ganador is string
                    && request.resource.data.ganador.size() > 0
                    && request.resource.data.premio is string;
      allow read: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // Sistema (backups, índices maestros): solo admin
    match /sistema/{docId} {
      allow read, write: if request.auth != null;
    }

  }
}
