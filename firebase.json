{
  "functions": {
    "source": "functions"
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/.git/**",
      "**/node_modules/**",
      "functions/**",
      "netlify/**",
      "*.md",
      "test_*.html",
      "*.ps1",
      "ANALISIS_*.md",
      "GUIA_*.md",
      "INSTRUCCIONES_*.md"
    ],
    "rewrites": [
      {
        "source": "/createPayment",
        "function": "createPaymentV2"
      },
      {
        "source": "/mercadopagoWebhook",
        "function": "mercadopagoWebhookV2"
      }
    ],
    "headers": [
      {
        "source": "**/*.@(html|js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          },
          {
            "key": "Pragma",
            "value": "no-cache"
          },
          {
            "key": "Expires",
            "value": "0"
          }
        ]
      }
    ]
  }
}
