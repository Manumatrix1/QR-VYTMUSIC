rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Fotos de audiciones: cualquiera puede subir imágenes hasta 5 MB
    match /audiciones_fotos/{fileName} {
      allow read: if true;
      allow write: if request.resource.size < 10 * 1024 * 1024
                   && (request.resource.contentType.matches('image/.*')
                       || request.resource.contentType == 'application/octet-stream');
    }
    // Videos de audiciones: cualquiera puede subir videos hasta 200 MB
    match /audiciones_videos/{fileName} {
      allow read: if true;
      allow write: if request.resource.size < 200 * 1024 * 1024
                   && request.resource.contentType.matches('video/.*');
    }
    // Comprobantes de pago de preventa: artistas sin login pueden subir y leer
    match /payment_proofs/{eventId}/{fileName} {
      allow read: if true;
      allow write: if request.resource.size < 10 * 1024 * 1024
                   && (request.resource.contentType.matches('image/.*')
                       || request.resource.contentType == 'application/pdf');
    }
    // Comprobantes de inscripción: artistas sin login pueden subir imágenes/PDFs hasta 10 MB
    match /inscripcion_comprobantes/{fileName} {
      allow read: if true;
      allow write: if request.resource.size < 10 * 1024 * 1024;
    }
    // Pistas de audio: artistas sin login pueden subir y leer (mp3/wav/mpeg/ogg hasta 100 MB)
    match /pistas/{eventId}/{artistId}/{fileName} {
      allow read: if true;
      allow write: if request.resource.size < 100 * 1024 * 1024
                   && (request.resource.contentType.matches('audio/.*')
                       || request.resource.contentType.matches('video/mpeg')
                       || request.resource.contentType == 'application/octet-stream');
    }
    // Todo lo demás requiere autenticación
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
