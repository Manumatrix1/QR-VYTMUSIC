rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // ✅ Helper: validar extensión del archivo
    function validExtension(extensions) {
      return request.resource.name.matches('.*\\.(' + extensions + ')$');
    }
    
    // ✅ Helper: validar tamaño
    function validSize(maxSizeMB) {
      return request.resource.size < maxSizeMB * 1024 * 1024;
    }
    
    // Fotos de audiciones: cualquier imagen hasta 20MB (incluye HEIC de iPhone)
    match /audiciones_fotos/{fileName} {
      allow read: if true;
      allow write: if validSize(20)
                   && request.resource.contentType.matches('image/.*');
    }
    
    // Videos de audiciones: cualquier video hasta 300MB (sin validar contentType — iOS/Android pueden enviar application/octet-stream)
    match /audiciones_videos/{fileName} {
      allow read: if true;
      allow write: if validSize(300);
    }
    
    // Comprobantes de pago: validación estricta
    match /payment_proofs/{eventId}/{fileName} {
      allow read: if true;
      allow write: if validSize(5)
                   && validExtension('jpg|jpeg|png|pdf|webp')
                   && (request.resource.contentType.matches('image/.*')
                       || request.resource.contentType == 'application/pdf');
    }
    
    // Comprobantes de inscripción: validación mejorada
    match /inscripcion_comprobantes/{fileName} {
      allow read: if true;
      allow write: if validSize(5)
                   && validExtension('jpg|jpeg|png|pdf|webp')
                   && (request.resource.contentType.matches('image/.*')
                       || request.resource.contentType == 'application/pdf');
    }
    
    // Pistas de audio: permite cualquier formato de audio (iPhones usan audio/mp4, audio/x-m4a, etc.)
    match /pistas/{eventId}/{artistId}/{fileName} {
      allow read: if true;
      allow write: if validSize(150)
                   && validExtension('mp3|wav|m4a|ogg|aac|mpeg|mpga|mp4');
    }
    
    // Pistas de organización: acceso sin autenticación (integrantes de org con link)
    match /pistas_organizacion/{eventId}/{fileName} {
      allow read: if true;
      allow delete: if true;
      allow create, update: if validSize(100)
                   && validExtension('mp3|wav|m4a|ogg|aac|mpeg|mpga')
                   && request.resource.contentType.matches('audio/.*');
    }
    
    // Todo lo demás requiere autenticación
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
