<!-- SVG convertido a PNG para 512x512 -->
<svg width="512" height="512" xmlns="http://www.w3.org/2000/svg">
  <rect width="512" height="512" fill="white" rx="80"/>
  <circle cx="256" cy="200" r="120" fill="none" stroke="#3b82f6" stroke-width="8" opacity="0.3"/>
  <circle cx="256" cy="200" r="90" fill="none" stroke="#0ea5e9" stroke-width="6" opacity="0.4"/>
  <circle cx="256" cy="200" r="60" fill="none" stroke="#06b6d4" stroke-width="4" opacity="0.5"/>
  
  <!-- Figura humana -->
  <g fill="#000000" stroke="white" stroke-width="6">
    <circle cx="256" cy="120" r="30"/>
    <ellipse cx="256" cy="180" rx="20" ry="40"/>
    <ellipse cx="200" cy="160" rx="12" ry="30" transform="rotate(-30 200 160)"/>
    <ellipse cx="300" cy="170" rx="10" ry="25" transform="rotate(20 300 170)"/>
    <ellipse cx="235" cy="250" rx="12" ry="35" transform="rotate(-15 235 250)"/>
    <ellipse cx="280" cy="255" rx="12" ry="35" transform="rotate(20 280 255)"/>
  </g>
  
  <!-- Micrófono -->
  <circle cx="150" cy="140" r="15" fill="#64748b" stroke="white" stroke-width="3"/>
  <rect x="145" y="120" width="10" height="30" fill="#64748b"/>
  
  <!-- Notas musicales -->
  <text x="350" y="100" font-size="40" fill="#3b82f6">♪</text>
  <text x="380" y="150" font-size="30" fill="#0ea5e9">♫</text>
  <text x="400" y="200" font-size="25" fill="#06b6d4">♪</text>
  
  <!-- Texto VYT-MUSIC -->
  <text x="256" y="400" font-family="Arial Black" font-size="48" font-weight="900" text-anchor="middle" fill="#1d4ed8" stroke="white" stroke-width="3">VYT-MUSIC</text>
</svg>